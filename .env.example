# BaoPixel Studio OS — Variables d'environnement
# Copiez ce fichier en .env.local pour le développement
# Sur Vercel : Settings → Environment Variables

# Chatbot Ollama (LOCAL - gratuit)
# Lancez simplement: ollama run mistral
# Aucune clé API nécessaire, fonctionne sur http://localhost:11434

# Token d'intégration Notion
# Créez une intégration sur https://www.notion.so/my-integrations
NOTION_TOKEN=ntn_remplacer_par_votre_token
ANTHROPIC_API_KEY=sk-ant-...

# Token d'intégration Notion — pour sync calendriers et tâches
# Créez une intégration sur https://www.notion.so/my-integrations
# Partagez vos bases de données avec l'intégration
NOTION_TOKEN=secret_...

# IDs des bases Notion (déjà pré-configurés avec vos calendriers)
NOTION_DB_BAOPIXEL=2c4387c253b080d7a2dde2515f435c89
NOTION_DB_AVRIL2026=acd387c253b082c0a5b381d27d1371f8
NOTION_DB_TASKS=034af88566a44040921ef87108c58a10
